DEBUG=true
# true = enable Dev login locally; set false on Vercel/production (Google Sign-In still works either way)
AUTH_DEV_MODE=true
# Neon pooled URL — quote the value if it contains & (sslmode/channel_binding are stripped for asyncpg)
DATABASE_URL="postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
# Mobile app backend URL (used by scripts/sync-mobile-dart-defines.sh)
API_BASE_URL=http://10.0.2.2:8000
# For Vercel/staging: API_BASE_URL=https://ab.smartops1.vercel.app
APP_ENV=dev
MIN_SUPPORTED_APP_VERSION=1.0.0
LATEST_APP_VERSION=1.0.0
MIN_SUPPORTED_SCHEMA_VERSION=1
ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.smartops.app
IOS_STORE_URL=
SENTRY_DSN=
